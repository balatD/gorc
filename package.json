{
  "name": "@balatd/gorc",
  "version": "0.1.1",
  "description": "A conductor agent plus a fleet of cheap subagents (research, reader, implementer, qa) for opencode. The conductor plans and delegates; the fleet does the grinding.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Dragan Balatinac"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/balatD/gorc.git"
  },
  "homepage": "https://github.com/balatD/gorc#readme",
  "keywords": [
    "opencode-plugin",
    "opencode",
    "orchestration",
    "agents",
    "subagents",
    "conductor",
    "fleet"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "files": ["dist", "agents", "commands"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node",
    "pretest": "bun run build",
    "test": "bun ./test/smoke.mjs"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.1"
  }
}